{
  "name": "instrumentality-vscode",
  "displayName": "Instrumentality",
  "description": "Surfaces knowledge-base drift, conform-pending, promotions, and lint state from the kb-mcp server.",
  "version": "0.3.0",
  "private": true,
  "publisher": "instrumentality",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:knowledge/_rules.md",
    "workspaceContains:knowledge/sync",
    "workspaceContains:knowledge/_index.yaml"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "instrumentality",
          "title": "Instrumentality",
          "icon": "media/mcp-logo-small.svg"
        }
      ]
    },
    "views": {
      "instrumentality": [
        {
          "id": "instrumentality.tree",
          "name": "Sync State",
          "icon": "media/mcp-logo-small.svg",
          "contextualTitle": "Instrumentality"
        },
        {
          "id": "instrumentality.details",
          "name": "Details",
          "type": "webview",
          "icon": "media/mcp-logo-small.svg",
          "contextualTitle": "Instrumentality"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "instrumentality.tree",
        "contents": "No knowledge base detected in the open workspace.\n\nInstrumentality looks for `knowledge/_rules.md`, `knowledge/sync/`, `knowledge/_index.yaml`, or `knowledge/_mcp/server.js` in the workspace folders.\n\n[Open Folder](command:vscode.openFolder)\n[Refresh](command:instrumentality.refresh)\n\nTo bootstrap a new project, run `kb_init` via your agent."
      }
    ],
    "commands": [
      { "command": "instrumentality.refresh", "title": "Instrumentality: Refresh", "icon": "$(refresh)" },
      { "command": "instrumentality.copyPrompt", "title": "Instrumentality: Copy Prompt", "icon": "$(clippy)" },
      { "command": "instrumentality.sendPrompt", "title": "Instrumentality: Send Prompt to Active Agent", "icon": "$(send)" },
      { "command": "instrumentality.openSource", "title": "Instrumentality: Open Source File", "icon": "$(go-to-file)" },
      { "command": "instrumentality.openStandard", "title": "Instrumentality: Open Standard Definition", "icon": "$(law)" },
      { "command": "instrumentality.editStandardRule", "title": "Instrumentality: Edit Standard Rule", "icon": "$(edit)" },
      { "command": "instrumentality.refineStandard", "title": "Instrumentality: Refine Standard with Agent", "icon": "$(sparkle)" },
      { "command": "instrumentality.groupBy", "title": "Instrumentality: Group By...", "icon": "$(group-by-ref-type)" },
      { "command": "instrumentality.openDashboard", "title": "Instrumentality: Open Dashboard", "icon": "$(dashboard)" },
      { "command": "instrumentality.sortBy", "title": "Instrumentality: Sort By...", "icon": "$(sort-precedence)" },
      { "command": "instrumentality.filter", "title": "Instrumentality: Filter...", "icon": "$(filter)" },
      { "command": "instrumentality.clearFilter", "title": "Instrumentality: Clear Filter", "icon": "$(clear-all)" }
    ],
    "menus": {
      "view/title": [
        { "command": "instrumentality.refresh", "when": "view == instrumentality.tree", "group": "navigation@1" },
        { "command": "instrumentality.openDashboard", "when": "view == instrumentality.tree", "group": "navigation@2" },
        { "command": "instrumentality.sortBy", "when": "view == instrumentality.tree", "group": "1_view@1" },
        { "command": "instrumentality.groupBy", "when": "view == instrumentality.tree", "group": "1_view@2" },
        { "command": "instrumentality.filter", "when": "view == instrumentality.tree", "group": "1_view@3" },
        { "command": "instrumentality.clearFilter", "when": "view == instrumentality.tree && instrumentality.filterActive", "group": "1_view@4" }
      ],
      "view/item/context": [
        { "command": "instrumentality.sendPrompt", "when": "view == instrumentality.tree && viewItem =~ /instrumentality.entry/", "group": "inline@1" },
        { "command": "instrumentality.copyPrompt", "when": "view == instrumentality.tree && viewItem =~ /instrumentality.entry/", "group": "1_actions@1" },
        { "command": "instrumentality.openSource", "when": "view == instrumentality.tree && viewItem =~ /instrumentality.entry/", "group": "1_actions@2" },
        { "command": "instrumentality.openStandard", "when": "view == instrumentality.tree && viewItem == instrumentality.entry.standard", "group": "1_actions@3" },
        { "command": "instrumentality.editStandardRule", "when": "view == instrumentality.tree && viewItem == instrumentality.entry.standard", "group": "1_actions@4" },
        { "command": "instrumentality.refineStandard", "when": "view == instrumentality.tree && viewItem == instrumentality.entry.standard", "group": "1_actions@5" }
      ]
    },
    "configuration": {
      "title": "Instrumentality",
      "properties": {
        "instrumentality.agent.backend": {
          "type": "string",
          "enum": ["clipboard", "terminal", "command"],
          "default": "clipboard",
          "description": "How 'Send Prompt' delivers the generated prompt. 'clipboard' copies it (you paste into the agent). 'terminal' types it into the active terminal. 'command' invokes a VS Code command id (set instrumentality.agent.commandId)."
        },
        "instrumentality.agent.commandId": {
          "type": "string",
          "default": "",
          "description": "VS Code command id to invoke when instrumentality.agent.backend is 'command'. The command receives the prompt string as its first argument. Example: 'workbench.action.terminal.sendSequence'."
        },
        "instrumentality.notifications.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Show toast notifications when sync state worsens (new errors, large delta, baseline change). Off by default — enable after you've tuned the rest."
        },
        "instrumentality.refreshIntervalSeconds": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Auto-refresh interval in seconds. 0 = file-watch only (default). Set to 30+ for unreliable network filesystems."
        },
        "instrumentality.lint.command": {
          "type": "string",
          "default": "",
          "description": "Override the lint command. Default tries '<kbRoot>/knowledge/_mcp/scripts/lint-standalone.js'. Set to e.g. 'npx kb-lint' or '/abs/path/to/lint-standalone.js' if your project uses an installed kb-mcp."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "vscode:prepublish": "node esbuild.config.js --production",
    "package": "vsce package"
  },
  "dependencies": {
    "@instrumentality/shared": "file:../shared"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  }
}
